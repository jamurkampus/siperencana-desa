// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUM ────────────────────────────────────────────────────────────────────

enum BidangKegiatan {
  PENYELENGGARAAN_PEMERINTAHAN
  PEMBANGUNAN_DESA
  PEMBERDAYAAN_MASYARAKAT
  PEMBINAAN_KEMASYARAKATAN
  PENANGGULANGAN_BENCANA
  KEADAAN_DARURAT
  MENDESAK
}

enum SumberDana {
  ADD    // Alokasi Dana Desa
  DD     // Dana Desa (APBN)
  PAD    // Pendapatan Asli Desa
  APBD_KAB
  APBD_PROV
  BANTUAN_PROVINSI
  BANTUAN_KABUPATEN
  LAINNYA
}

enum StatusKegiatan {
  DRAFT
  DIAJUKAN
  DISETUJUI
  BERJALAN
  SELESAI
  DITOLAK
}

enum JenisDokumen {
  PROPOSAL
  RAB
  KAK
  SK_PANITIA
  SURAT_TUGAS
  BERITA_ACARA
  LAPORAN_PELAKSANAAN
}

enum StatusDokumen {
  DRAFT
  FINAL
  DITANDATANGANI
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model Desa {
  id              String   @id @default(cuid())
  namaDesaLengkap String
  namaDesa        String
  kecamatan       String
  kabupaten       String
  provinsi        String
  kodePos         String?
  kepalaDesaNama  String
  kepalaDesaNip   String?
  sekdesNama      String?
  kaurPerencNama  String
  kaurPerencNip   String?
  bendaharaNama   String?
  alamatKantor    String?
  telepon         String?
  email           String?
  website         String?
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kegiatan Kegiatan[]
}

model TahunAnggaran {
  id        String   @id @default(cuid())
  tahun     Int      @unique
  isAktif   Boolean  @default(false)
  createdAt DateTime @default(now())

  kegiatan Kegiatan[]
}

model Kegiatan {
  id              String         @id @default(cuid())
  kodeKegiatan    String?        @unique
  namaKegiatan    String
  bidang          BidangKegiatan
  lokasi          String
  volume          Float
  satuan          String
  tahunAnggaranId String
  sumberDana      SumberDana
  pelaksana       String
  sasaran         String         @db.Text
  manfaat         String         @db.Text
  latarBelakang   String?        @db.Text
  tujuan          String?        @db.Text
  uraianKegiatan  String?        @db.Text
  anggaran        Decimal        @db.Decimal(15, 2)
  status          StatusKegiatan @default(DRAFT)
  desaId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  desa          Desa          @relation(fields: [desaId], references: [id])
  tahunAnggaran TahunAnggaran @relation(fields: [tahunAnggaranId], references: [id])
  jadwal        JadwalKegiatan[]
  panitia       Panitia[]
  dokumen       Dokumen[]
  rab           RabItem[]

  @@index([desaId])
  @@index([status])
  @@index([tahunAnggaranId])
}

model JadwalKegiatan {
  id          String   @id @default(cuid())
  kegiatanId  String
  bulan       Int      // 1-12
  keterangan  String?
  createdAt   DateTime @default(now())

  kegiatan Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@index([kegiatanId])
}

model Panitia {
  id         String   @id @default(cuid())
  kegiatanId String
  nama       String
  jabatan    String   // Ketua, Sekretaris, Anggota, dll
  nip        String?
  nik        String?
  createdAt  DateTime @default(now())

  kegiatan Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@index([kegiatanId])
}

model RabItem {
  id          String   @id @default(cuid())
  kegiatanId  String
  uraian      String
  satuan      String
  volume      Float
  hargaSatuan Decimal  @db.Decimal(15, 2)
  total       Decimal  @db.Decimal(15, 2)
  keterangan  String?
  urutan      Int      @default(0)
  createdAt   DateTime @default(now())

  kegiatan Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@index([kegiatanId])
}

model Dokumen {
  id           String        @id @default(cuid())
  kegiatanId   String
  jenis        JenisDokumen
  nomor        String?
  judul        String
  konten       Json          // Stores document content/data
  status       StatusDokumen @default(DRAFT)
  fileUrl      String?
  tanggalBuat  DateTime      @default(now())
  tanggalTanda DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  kegiatan Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@index([kegiatanId])
  @@index([jenis])
}

model AiHistory {
  id        String   @id @default(cuid())
  prompt    String   @db.Text
  response  String   @db.Text
  konteks   String?  // kegiatan name for context
  createdAt DateTime @default(now())
}
